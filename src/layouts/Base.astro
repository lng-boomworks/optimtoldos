---
import '../styles/global.css';
import { url } from '../utils/paths';
import type { Locale } from '../i18n/index';
import { ogLocales } from '../i18n/index';
import { WhatsAppButton } from '../components/WhatsAppButton';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  breadcrumbs?: Breadcrumb[];
  locale?: Locale;
  alternateUrls?: { locale: string; href: string }[];
}

const {
  title,
  description = 'Especialistas en protección solar y vida exterior en Alicante. Toldos, pérgolas bioclimáticas, cortinas de cristal, velas de sombra y ventanas PVC.',
  ogImage = '/images/og-default.jpg',
  type = 'website',
  noindex = false,
  breadcrumbs,
  locale = 'es' as Locale,
  alternateUrls = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Optim Toldos" />
    <meta property="og:locale" content={ogLocales[locale]} />
    {alternateUrls.map(alt => (
      <link rel="alternate" hreflang={alt.locale} href={alt.href} />
    ))}
    {alternateUrls.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.locale === 'es')?.href ?? alternateUrls[0].href} />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
    <link rel="icon" href={url("/favicon.ico")} sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href={url("/favicon-32.png")} />
    <link rel="apple-touch-icon" href={url("/apple-touch-icon.png")} />
    <link rel="manifest" href={url("/manifest.json")} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- JSON-LD: LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://optimtoldos.com/#business",
      "name": "Optim Toldos",
      "description": locale === 'en'
        ? "Specialists in solar protection and outdoor living. Awnings, bioclimatic pergolas, glass curtains, shade sails and PVC windows in Alicante."
        : "Especialistas en protección solar y vida exterior. Toldos, pérgolas bioclimáticas, cortinas de cristal, velas de sombra y ventanas PVC en Alicante.",
      "url": "https://optimtoldos.com",
      "telephone": "+34 603 572 348",
      "email": "info@optimtoldos.com",
      "image": [
        "https://optimtoldos.com/images/gallery/hero-toldos-2025.jpg",
        "https://optimtoldos.com/images/pergolas/pergola-bioclimatica.jpg",
        "https://optimtoldos.com/images/cortinas/cortina-cristal-1.jpg"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Elche",
        "addressRegion": "Alicante",
        "postalCode": "03200",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 38.2669,
        "longitude": -0.6986
      },
      "areaServed": [
        { "@type": "City", "name": "Alicante" },
        { "@type": "City", "name": "Elche" },
        { "@type": "City", "name": "Torrevieja" },
        { "@type": "City", "name": "Benidorm" },
        { "@type": "City", "name": "Santa Pola" },
        { "@type": "City", "name": "Orihuela" },
        { "@type": "City", "name": "Guardamar del Segura" },
        { "@type": "City", "name": "Dénia" },
        { "@type": "City", "name": "Jávea" },
        { "@type": "City", "name": "Altea" },
        { "@type": "City", "name": "Calpe" },
        { "@type": "City", "name": "San Vicente del Raspeig" },
        { "@type": "City", "name": "San Juan de Alicante" },
        { "@type": "City", "name": "Mutxamel" },
        { "@type": "City", "name": "El Campello" },
        { "@type": "City", "name": "Villajoyosa" },
        { "@type": "City", "name": "Alcoy" },
        { "@type": "City", "name": "Elda" },
        { "@type": "City", "name": "Petrer" },
        { "@type": "City", "name": "Novelda" }
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "19:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "14:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "127",
        "bestRating": "5"
      },
      "knowsLanguage": ["es", "en"],
      "priceRange": "€€"
    })} />

    <!-- JSON-LD: BreadcrumbList -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((item: Breadcrumb, i: number) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": item.name,
          "item": item.url
        }))
      })} />
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <slot />
    <WhatsAppButton client:load locale={locale} />
  </body>
</html>
