---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Navbar } from '../../../components/Navbar';
import { Footer } from '../../../components/Footer';
import { url } from '../../../utils/paths';
import { buildCollectionPageSchema } from '../../../utils/schema';
import { t } from '../../../i18n/index';
import { getAlternateUrls } from '../../../i18n/routes';

const alternateUrls = getAlternateUrls('blog');

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => (p.data.locale ?? 'es') === 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function postSlug(id: string): string {
  return id.replace(/^es\//, '').replace(/^en\//, '');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://optimtoldos.com/en/' },
  { name: 'Blog', url: 'https://optimtoldos.com/en/blog' },
];

const categoryLabels: Record<string, string> = {
  guias: 'Guides',
  consejos: 'Tips',
  tendencias: 'Trends',
  normativa: 'Regulations',
  'casos-de-exito': 'Case Studies',
  guides: 'Guides',
  tips: 'Tips',
  trends: 'Trends',
  regulations: 'Regulations',
  'case-studies': 'Case Studies',
};

const collectionSchema = buildCollectionPageSchema({
  name: "Blog | Optim Toldos",
  description: "Guides, tips and news about awnings, bioclimatic pergolas, glass curtains, shade sails and PVC windows in Alicante.",
  url: "https://optimtoldos.com/en/blog",
  items: posts.map((post) => ({
    name: post.data.title,
    url: `https://optimtoldos.com/en/blog/${postSlug(post.id)}`,
  })),
});
---

<Base
  title="Blog | Optim Toldos — Solar Protection Guides & Tips"
  description="Guides, tips and news about awnings, bioclimatic pergolas, glass curtains, shade sails and PVC windows in Alicante."
  locale="en"
  alternateUrls={alternateUrls}
  breadcrumbs={breadcrumbs}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>
  <Navbar client:load locale="en" alternates={alternateUrls} />

  <main>
    <!-- Hero -->
    <section class="bg-navy pt-32 pb-20">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h1 class="font-serif text-4xl md:text-5xl text-white mb-6">Blog</h1>
        <p class="text-lg text-white/70 max-w-2xl mx-auto">
          Guides, tips and news about solar protection and outdoor living in Alicante
        </p>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="bg-white py-20 md:py-28">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        {posts.length === 0 ? (
          <p class="text-center text-text-muted text-lg">Coming soon: articles and guides on solar protection.</p>
        ) : (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <a
                href={url(`/en/blog/${postSlug(post.id)}`)}
                class="group block rounded-2xl overflow-hidden bg-white border border-border shadow-sm hover:shadow-md transition-shadow duration-300"
              >
                {post.data.image ? (
                  <div class="relative overflow-hidden aspect-[16/10]">
                    <img
                      src={url(post.data.image)}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/10] bg-gradient-to-br from-terracotta/20 to-gold/10" />
                )}
                <div class="p-6">
                  <span class="inline-block font-mono text-xs tracking-wide text-terracotta uppercase mb-2">
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <h2 class="font-serif text-xl text-navy mb-2 group-hover:text-terracotta transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-text-muted text-sm leading-relaxed mb-3 line-clamp-2">
                    {post.data.description}
                  </p>
                  <span class="text-text-muted/60 text-xs">
                    {new Date(post.data.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer client:load locale="en" />
</Base>
