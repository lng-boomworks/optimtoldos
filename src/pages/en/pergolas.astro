---
import Base from '../../layouts/Base.astro';
import { PergolasPage } from '../../components/pages/PergolasPage';
import { buildServiceSchema, buildFAQSchema, buildProductSchema } from '../../utils/schema';
import { t } from '../../i18n/index';
import { getAlternateUrls } from '../../i18n/routes';

const alternateUrls = getAlternateUrls('pergolas');

const serviceSchema = buildServiceSchema({
  name: t('en', 'pergolas.hero.heading'),
  description: t('en', 'pergolas.hero.description'),
  serviceType: "Bioclimatic Pergola Installation",
  url: "https://optimtoldos.com/en/pergolas",
  offers: [
    { name: "Bioclimatic Pergola" },
    { name: "Wall-Mounted Pergola" },
    { name: "Freestanding Pergola" },
  ],
});

const faqSchema = buildFAQSchema([
  { question: t('en', 'pergolas.faq.1.q'), answer: t('en', 'pergolas.faq.1.a') },
  { question: t('en', 'pergolas.faq.2.q'), answer: t('en', 'pergolas.faq.2.a') },
  { question: t('en', 'pergolas.faq.3.q'), answer: t('en', 'pergolas.faq.3.a') },
  { question: t('en', 'pergolas.faq.4.q'), answer: t('en', 'pergolas.faq.4.a') },
  { question: t('en', 'pergolas.faq.5.q'), answer: t('en', 'pergolas.faq.5.a') },
  { question: t('en', 'pergolas.faq.6.q'), answer: t('en', 'pergolas.faq.6.a') },
]);

const productSchema = buildProductSchema({
  name: "Bioclimatic Pergolas in Alicante",
  description: "Aluminium bioclimatic pergolas with adjustable louvres, motorisation and integrated LED lighting. Custom-made and professionally installed.",
  image: "https://optimtoldos.com/images/pergolas/hero-pergolas.webp",
  url: "https://optimtoldos.com/en/pergolas",
  lowPrice: "3000",
  highPrice: "12000",
  category: "Bioclimatic pergolas",
});
---

<Base
  title="Bioclimatic Pergolas | Optim Toldos — Alicante"
  description="Aluminium pergolas with adjustable louvres. Control light, ventilation and rain protection. Professional installation in Alicante and Costa Blanca."
  locale="en"
  alternateUrls={alternateUrls}
  breadcrumbs={[
    { name: "Home", url: "https://optimtoldos.com/en/" },
    { name: "Pergolas", url: "https://optimtoldos.com/en/pergolas" },
  ]}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>
  <PergolasPage client:load locale="en" />
</Base>
