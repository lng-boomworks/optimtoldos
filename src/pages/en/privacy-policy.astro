---
import Base from '../../layouts/Base.astro';
import { Navbar } from '../../components/Navbar';
import { Footer } from '../../components/Footer';
import { getAlternateUrls } from '../../i18n/routes';

const alternateUrls = getAlternateUrls('privacy-policy');

const breadcrumbs = [
  { name: "Home", url: "https://optimtoldos.com/en/" },
  { name: "Privacy Policy", url: "https://optimtoldos.com/en/privacy-policy" },
];
---

<Base
  title="Privacy Policy | Optim Toldos"
  description="Privacy policy of Optim Toldos: how we collect, process and protect your personal data in accordance with the GDPR and Spanish data protection law."
  breadcrumbs={breadcrumbs}
  locale="en"
  alternateUrls={alternateUrls}
>
  <Navbar client:load locale="en" />

  <main class="pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-serif text-4xl md:text-5xl text-navy mb-4">Privacy Policy</h1>
      <p class="text-text-muted text-sm mb-10">Last updated: 17 April 2026</p>

      <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-navy prose-a:text-terracotta">
        <h2>1. Data controller</h2>
        <ul>
          <li>Controller: Optim Toldos [EDIT: confirm legal business name]</li>
          <li>Tax ID (NIF/CIF): [EDIT]</li>
          <li>Address: [EDIT], Elche, Alicante 03200, Spain</li>
          <li>Email: info@optimtoldos.com</li>
          <li>Phone: +34 603 572 348</li>
        </ul>

        <h2>2. Purpose of processing</h2>
        <p>We collect and process your personal data for the following purposes:</p>
        <ul>
          <li>To handle quote requests submitted through our forms.</li>
          <li>To respond to enquiries made by email, phone or contact form.</li>
          <li>To send you information about our products and services, only if you have given your consent.</li>
          <li>To comply with any legal obligations that apply to us.</li>
        </ul>

        <h2>3. Data collected</h2>
        <ul>
          <li>Identification data: name, surname, address.</li>
          <li>Contact data: email, phone.</li>
          <li>Installation data: location, dimensions, product type.</li>
          <li>Technical data: IP address, browser type, pages visited (only with analytics cookies, if accepted).</li>
        </ul>

        <h2>4. Legal basis</h2>
        <ul>
          <li>Explicit consent of the user when completing the forms.</li>
          <li>Pre-contractual execution when the user requests a quote.</li>
          <li>Legitimate interest in responding to enquiries.</li>
          <li>Compliance with legal obligations (tax, commercial).</li>
        </ul>

        <h2>5. Retention period</h2>
        <p>
          Data will be kept for as long as necessary to fulfil the purpose for which it was collected, and thereafter for the applicable legal retention periods (up to 6 years for tax and commercial obligations).
        </p>

        <h2>6. Recipients of the data</h2>
        <p>Your data may be shared with:</p>
        <ul>
          <li>Technology service providers (email hosting, cloud storage) under a data processing agreement.</li>
          <li>Public authorities where there is a legal obligation to do so.</li>
          <li>[EDIT: add other recipients if applicable]</li>
        </ul>
        <p>No international data transfers are made outside the European Economic Area.</p>

        <h2>7. User rights</h2>
        <p>You can exercise the following rights over your personal data:</p>
        <ul>
          <li>Access: to know what data we hold about you.</li>
          <li>Rectification: to correct inaccurate or incomplete data.</li>
          <li>Erasure: to request the deletion of your data.</li>
          <li>Objection: to object to the processing of your data.</li>
          <li>Restriction: to request the restriction of processing.</li>
          <li>Portability: to receive your data in a structured format.</li>
          <li>Withdrawal of consent.</li>
        </ul>
        <p>
          To exercise these rights, send an email to <a href="mailto:info@optimtoldos.com">info@optimtoldos.com</a> with the subject "Data protection", enclosing a copy of your ID or identification document.
        </p>

        <h2>8. Complaints</h2>
        <p>
          If you believe that the processing of your data does not comply with the applicable regulations, you can file a complaint with the Spanish Data Protection Agency (AEPD), C/ Jorge Juan 6, 28001 Madrid, or via <a href="https://www.aepd.es" target="_blank" rel="noopener noreferrer">www.aepd.es</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer client:load locale="en" />
</Base>
