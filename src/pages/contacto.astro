---
import Base from '../layouts/Base.astro';
import { ContactoPage } from '../components/pages/ContactoPage';
import { buildContactPageSchema } from '../utils/schema';
import { getAlternateUrls } from '../i18n/routes';

const alternateUrls = getAlternateUrls('contact');

const schema = buildContactPageSchema({
  url: "https://optimtoldos.com/contacto",
  telephone: "+34 603 572 348",
  email: "info@optimtoldos.com",
});

const breadcrumbs = [
  { name: "Inicio", url: "https://optimtoldos.com/" },
  { name: "Contacto", url: "https://optimtoldos.com/contacto" },
];
---

<Base title="Contacto | Optim Toldos — Alicante" description="Contacta con Optim Toldos en Elche, Alicante. Toldos, pérgolas, cortinas de cristal, velas de sombra y ventanas PVC. Presupuesto sin compromiso." breadcrumbs={breadcrumbs} locale="es" alternateUrls={alternateUrls}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <ContactoPage client:load locale="es" />
</Base>
