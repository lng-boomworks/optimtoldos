---
import Base from '../layouts/Base.astro';
import { GaleriaPage } from '../components/pages/GaleriaPage';
import { buildCollectionPageSchema } from '../utils/schema';
import { getAlternateUrls } from '../i18n/routes';

const alternateUrls = getAlternateUrls('gallery');

const schema = buildCollectionPageSchema({
  name: "Galería de Proyectos",
  description: "Galería de proyectos realizados: toldos, pérgolas bioclimáticas, cortinas de cristal y más en Alicante y Costa Blanca.",
  url: "https://optimtoldos.com/galeria",
  items: [
    { name: "Toldos", url: "https://optimtoldos.com/galeria" },
    { name: "Pérgolas", url: "https://optimtoldos.com/galeria" },
    { name: "Cortinas de Cristal", url: "https://optimtoldos.com/galeria" },
    { name: "Velas de Sombra", url: "https://optimtoldos.com/galeria" },
    { name: "Ventanas PVC", url: "https://optimtoldos.com/galeria" },
  ],
});

const breadcrumbs = [
  { name: "Inicio", url: "https://optimtoldos.com/" },
  { name: "Galería", url: "https://optimtoldos.com/galeria" },
];
---

<Base title="Galería de Proyectos | Optim Toldos — Alicante" description="Galería de proyectos realizados: toldos, pérgolas bioclimáticas, cortinas de cristal y más en Alicante y Costa Blanca." breadcrumbs={breadcrumbs} locale="es" alternateUrls={alternateUrls}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <GaleriaPage client:load locale="es" />
</Base>
